<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adriana Almeida | Buffet, Cerimonial e Assessoria</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        /* Cores: Preto (#0d0d0d), Dourado (#d4af37), Vermelho (#c0392b) */
        :root {
            --bg-dark: #0d0d0d;
            --bg-light: #1a1a1a;
            --gold: #d4af37;
            --gold-hover: #f3e5ab;
            --red-cta: #c0392b;
            --red-hover: #e74c3c;
            --text-light: #ffffff;
            --text-muted: #cccccc;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Montserrat', sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            scroll-behavior: smooth;
        }

        h1, h2, h3, .brand-name {
            font-family: 'Cinzel', serif;
            color: var(--gold);
            text-align: center;
        }

        /* Topo / Header */
        header {
            background-color: rgba(13, 13, 13, 0.95);
            padding: 20px;
            border-bottom: 2px solid var(--gold);
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .brand-subtitle {
            font-size: 0.9rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--text-light);
            margin-top: 5px;
        }

        /* Seção Hero (Abertura) */
        .hero {
            padding: 100px 20px;
            text-align: center;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.85)), url('https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1920') no-repeat center center/cover;
            border-bottom: 1px solid rgba(212, 175, 55, 0.3);
        }

        .hero h2 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            color: var(--text-light);
        }

        .hero p {
            font-size: 1.2rem;
            max-width: 600px;
            margin: 0 auto 30px;
            color: var(--text-muted);
        }

        /* Botão de Destaque Vermelho */
        .btn-cta {
            display: inline-block;
            background-color: var(--red-cta);
            color: white;
            padding: 15px 35px;
            font-weight: bold;
            text-transform: uppercase;
            text-decoration: none;
            border-radius: 5px;
            transition: 0.3s;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(192, 57, 43, 0.4);
        }

        .btn-cta:hover {
            background-color: var(--red-hover);
            transform: translateY(-2px);
        }

        /* Seção Serviços */
        .services {
            padding: 80px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .services h2 {
            font-size: 2.2rem;
            margin-bottom: 50px;
            position: relative;
        }

        .services h2::after {
            content: '👑';
            display: block;
            font-size: 1.2rem;
            margin-top: 10px;
        }

        .grid-services {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .card {
            background-color: var(--bg-light);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 8px;
            overflow: hidden;
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: var(--gold);
        }

        .card-img {
            height: 220px;
            background-size: cover;
            background-position: center;
        }

        .card-title {
            padding: 20px;
            text-align: center;
            font-size: 1.2rem;
            font-weight: 500;
        }

        /* Seção Depoimentos */
        .testimonials {
            background-color: var(--bg-light);
            padding: 80px 20px;
            border-top: 1px solid rgba(212, 175, 55, 0.1);
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
        }

        .testimonials h2 {
            margin-bottom: 50px;
        }

        .grid-testimonials {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .testimonial-item {
            background-color: var(--bg-dark);
            padding: 30px;
            border-radius: 8px;
            border-left: 3px solid var(--gold);
        }

        .testimonial-item p {
            font-style: italic;
            color: var(--text-muted);
            margin-bottom: 15px;
            line-height: 1.6;
        }

        .testimonial-item h4 {
            color: var(--gold);
            font-size: 1rem;
        }

        /* Seção Orçamento (Formulário) */
        .budget {
            padding: 80px 20px;
            max-width: 600px;
            margin: 0 auto;
        }

        .budget h2 {
            margin-bottom: 15px;
        }

        .budget p {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 40px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .form-group label {
            color: var(--gold);
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        input, select, textarea {
            background-color: var(--bg-light);
            border: 1px solid rgba(212, 175, 55, 0.4);
            padding: 12px;
            color: white;
            border-radius: 4px;
            font-size: 1rem;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 5px rgba(212, 175, 55, 0.5);
        }

        /* Rodapé */
        footer {
            background-color: #050505;
            padding: 40px 20px;
            text-align: center;
            border-top: 2px solid var(--gold);
        }

        .footer-contact {
            margin-bottom: 25px;
            font-size: 1.3rem;
        }

        .footer-contact a {
            color: var(--text-light);
            text-decoration: none;
            font-weight: bold;
        }

        .footer-contact a:hover {
            color: var(--gold);
        }

        .social-links {
            margin-bottom: 20px;
        }

        .social-links a {
            color: var(--gold);
            font-size: 1.8rem;
            margin: 0 15px;
            transition: 0.3s;
        }

        .social-links a:hover {
            color: var(--gold-hover);
        }

        .footer-credits {
            font-size: 0.8rem;
            color: #666;
        }

        /* Botão Flutuante WhatsApp */
        .whatsapp-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background-color: #25d366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 1000;
            transition: 0.3s;
            text-decoration: none;
        }

        .whatsapp-float:hover {
            transform: scale(1.1);
            background-color: #128c7e;
        }

        @media (max-width: 768px) {
            .hero h2 { font-size: 1.8rem; }
            .services h2 { font-size: 1.8rem; }
        }
    </style>
</head>
<body>

    <header>
        <h1 class="brand-name">Adriana Almeida</h1>
        <div class="brand-subtitle">Buffet, Cerimonial e Assessoria</div>
    </header>

    <section class="hero">
        <h2>Transformamos o seu sonho em um evento inesquecível</h2>
        <p>Do planejamento à execução: alta gastronomia, organização impecável e assessoria completa para os momentos mais importantes da sua vida.</p>
        <a href="#orcamento" class="btn-cta">Fazer Orçamento Sem Compromisso</a>
    </section>

    <section class="services" id="servicos">
        <h2>Nossos Serviços</h2>
        
        <div class="grid-services">
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=600');"></div>
                <div class="card-title">Casamento</div>
            </div>
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=600');"></div>
                <div class="card-title">Formatura</div>
            </div>
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1511578314322-379afb476865?q=80&w=600');"></div>
                <div class="card-title">Corporativos</div>
            </div>
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=600');"></div>
                <div class="card-title">Coffee Break</div>
            </div>
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?q=80&w=600');"></div>
                <div class="card-title">Aniversário e Confraternização</div>
            </div>
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1530103862676-de8c9debad1d?q=80&w=600');"></div>
                <div class="card-title">Batizado e Chás (Bebê/Revelação)</div>
            </div>
        </div>
    </section>

    <section class="testimonials">
        <h2>O que nossos clientes dizem</h2>
        <div class="grid-testimonials">
            <div class="testimonial-item">
                <p>"A Adriana transformou o nosso casamento em um conto de fadas. O buffet estava impecável e a equipe super atenciosa. Recomendo de olhos fechados!"</p>
                <h4>— Mariana & Roberto</h4>
            </div>
            <div class="testimonial-item">
                <p>"Organizar o evento corporativo da nossa empresa parecia um desafio, mas a assessoria da Adriana cuidou de cada detalhe com extrema elegância e pontualidade."</p>
                <h4>— Carlos Souza (Diretor Executivo)</h4>
            </div>
            <div class="testimonial-item">
                <p>"O aniversário de 15 anos da minha filha foi perfeito. A mesa de doces e o cerimonial foram elogiados por todos os convidados!"</p>
                <h4>— Patrícia Lima</h4>
            </div>
        </div>
    </section>

    <section class="budget" id="orcamento">
        <h2>Solicite um Orçamento</h2>
        <p>Preencha os campos abaixo e nossa equipe entrará em contato para criar uma proposta personalizada para você.</p>
        
        <form action="#" method="POST">
            <div class="form-group">
                <label for="nome">Nome Completo</label>
                <input type="text" id="nome" name="nome" placeholder="Digite seu nome" required>
            </div>
            
            <div class="form-group">
                <label for="telefone">Telefone / WhatsApp</label>
                <input type="tel" id="telefone" name="telefone" placeholder="(XX) XXXXX-XXXX" required>
            </div>
            
            <div class="form-group">
                <label for="evento">O que você deseja?</label>
                <select id="evento" name="evento" required>
                    <option value="" disabled selected>Selecione o tipo de evento</option>
                    <option value="casamento">Casamento</option>
                    <option value="formatura">Formatura</option>
                    <option value="corporativo">Evento Corporativo</option>
                    <option value="coffee-break">Coffee Break</option>
                    <option value="aniversario">Aniversário / Confraternização</option>
                    <option value="batizado-chas">Batizado / Chá de Bebê / Revelação</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="mensagem">Detalhes do Evento</label>
                <textarea id="mensagem" name="mensagem" rows="4" placeholder="Conte-nos um pouco sobre a sua ideia (Data aproximada, número de convidados, etc.)"></textarea>
            </div>
            
            <button type="submit" class="btn-cta" style="width: 100%; border-radius: 4px;">Enviar Pedido de Orçamento</button>
        </form>
    </section>

    <footer>
        <div class="footer-contact">
            <p>Fale Conosco: <a href="https://wa.me/5575987001396" target="_blank">(75) 98700-1396</a></p>
        </div>
        
        <div class="social-links">
            <a href="https://instagram.com/adriana_cerimonialista" target="_blank" title="Instagram"><i class="fab fa-instagram"></i></a>
            <a href="https://wa.me/5575987001396" target="_blank" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
        </div>
        
        <div class="footer-credits">
            &copy; 2026 Adriana Almeida | Buffet, Cerimonial e Assessoria. Todos os direitos reservados.
        </div>
    </footer>

    <a href="https://wa.me/5575987001396" class="whatsapp-float" target="_blank" title="Fale pelo WhatsApp">
        <i class="fab fa-whatsapp"></i>
    </a>
